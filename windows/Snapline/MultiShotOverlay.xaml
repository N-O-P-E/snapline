<Window x:Class="Snapline.MultiShotOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize">
    <Border Background="#E61D1D1F" CornerRadius="10" Padding="16,12" BorderBrush="#3A3A3C" BorderThickness="1">
        <StackPanel Orientation="Horizontal">
            <Border Width="10" Height="10" Background="#FF3B30" CornerRadius="5" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock x:Name="TitleText"
                           Text="Multi-shot — 0 captured"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White"/>
                <TextBlock x:Name="HintText"
                           Text="Drag to snip. Press Esc to finish and paste."
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#B0B0B0"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
